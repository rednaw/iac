---
# Ansible Lint Configuration
# See: https://docs.ansible.com/projects/lint/configuring/

profile: production

# Skip style-only rules that don't affect functionality
skip_list:
  - yaml[empty-lines]         # Allow blank lines for readability
  - yaml[line-length]         # Allow long lines when necessary
  - var-naming[no-role-prefix]  # Don't require role prefix on internal variables

# Taskfiles live under tasks/ and match the default "**/tasks/*.yml" Ansible kind.
kinds:
  - yaml: "**/Taskfile.yml"
  - yaml: "**/Taskfile*.yml"

exclude_paths:
  - .cache/
  - .git/
  - venv/
  - ../Taskfile.yml
  - ../tasks/
