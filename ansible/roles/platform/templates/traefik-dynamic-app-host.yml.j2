# yaml-language-server: $schema=https://json.schemastore.org/traefik-v2.json
# ACME hostnames for platform routers (dev.<base_domain>, prod.<base_domain>). 
# App vanity domains come from docker-compose Traefik labels.
http:
  routers:
    app-host:
      rule: "Host(`{{ traefik_app_domains | join('`) || Host(`') }}`)"
      entryPoints:
        - websecure
      tls:
        certResolver: letsencrypt
      priority: -10
      service: noop@internal
