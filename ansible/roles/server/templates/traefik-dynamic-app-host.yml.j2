# yaml-language-server: $schema=https://json.schemastore.org/traefik-v2.json
# Router for main app hostname so Traefik requests a Let's Encrypt cert
# even when the app container is not running. Priority -1 so the app's Docker router wins when deployed.
http:
  routers:
    app-host:
      rule: "Host(`{{ traefik_redirect_target }}`)"
      entryPoints:
        - websecure
      tls:
        certResolver: letsencrypt
      priority: -1
      service: noop@internal
