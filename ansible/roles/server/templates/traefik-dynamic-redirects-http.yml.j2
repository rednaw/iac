# yaml-language-server: $schema=https://json.schemastore.org/traefik-v2.json
# Redirect HTTP (port 80) to HTTPS. Exclude ACME path so Let's Encrypt HTTP-01 can complete.
http:
  routers:
    to-https:
      rule: "HostRegexp(`.*`) && !PathPrefix(`/.well-known/acme-challenge`)"
      entryPoints:
        - web
      priority: 10000
      middlewares:
        - redirect-https
      service: noop@internal
  middlewares:
    redirect-https:
      redirectScheme:
        scheme: https
        permanent: true
