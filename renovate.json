{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "branchPrefix": "renovate-tmp/",
  "timezone": "Europe/Amsterdam",
  "minimumReleaseAge": "3 days",
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "prConcurrentLimit": 10,
  "branchConcurrentLimit": 10,
  "prHourlyLimit": 10,
  "automergeType": "pr",
  "platformAutomerge": true,
  "ignoreTests": false,
  "enabledManagers": [
    "github-actions",
    "dockerfile",
    "devcontainer",
    "terraform",
    "ansible",
    "ansible-galaxy",
    "pip_requirements",
    "custom.regex",
    "mise"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "mise.toml: tools not in Renovate's built-in mise short-name list (read package from # owner/repo comment)",
      "managerFilePatterns": ["mise.toml"],
      "matchStrings": ["(?<depName>\\w+)\\s*=\\s*\"(?<currentValue>[^\"]+)\"\\s*#\\s*(?<packageName>[^\\s\\n]+)"],
      "datasourceTemplate": "github-releases",
      "autoReplaceStringTemplate": "{{{depName}}} = \"{{{newValue}}}\"  # {{{packageName}}}"
    },
    {
      "customType": "regex",
      "description": "Crane version in Prefect worker Dockerfile (GitHub releases; gcr.io image outdated)",
      "managerFilePatterns": ["prefect/Dockerfile.worker"],
      "matchStrings": ["ARG CRANE_VERSION=(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)"],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "google/go-containerregistry",
      "autoReplaceStringTemplate": "ARG CRANE_VERSION={{{newValue}}}"
    }
  ],
  "schedule": ["at any time"],
  "packageRules": [
    {
      "description": "Single PR for all mise.toml bumps (native mise + regex tools)",
      "matchFileNames": ["mise.toml"],
      "groupName": "mise tooling",
      "commitMessageTopic": "{{#each upgrades}}{{{depName}}}{{#unless @last}}, {{/unless}}{{/each}}"
    },
    {
      "description": "Single PR for pip requirements files",
      "matchManagers": ["pip_requirements"],
      "groupName": "Python requirements",
      "commitMessageTopic": "{{#each upgrades}}{{{depName}}}{{#unless @last}}, {{/unless}}{{/each}}"
    },
    {
      "description": "Single PR for root Dockerfile (dev image bases)",
      "matchManagers": ["dockerfile"],
      "matchPaths": ["Dockerfile"],
      "groupName": "Devcontainer Dockerfile",
      "commitMessageTopic": "{{#each upgrades}}{{{depName}}}{{#unless @last}}, {{/unless}}{{/each}}"
    },
    {
      "description": "Single PR for Prefect worker Dockerfile (FROM lines + crane regex)",
      "matchManagers": ["dockerfile", "regex"],
      "matchPaths": ["prefect/Dockerfile.worker"],
      "groupName": "Prefect worker image",
      "commitMessageTopic": "{{#each upgrades}}{{{depName}}}{{#unless @last}}, {{/unless}}{{/each}}"
    },
    {
      "description": "Single PR for devcontainer.json image + features",
      "matchManagers": ["devcontainer"],
      "groupName": "Devcontainer config",
      "commitMessageTopic": "{{#each upgrades}}{{{depName}}}{{#unless @last}}, {{/unless}}{{/each}}"
    },
    {
      "description": "Single PR for Terraform",
      "matchManagers": ["terraform"],
      "groupName": "Terraform",
      "commitMessageTopic": "{{#each upgrades}}{{{depName}}}{{#unless @last}}, {{/unless}}{{/each}}"
    },
    {
      "description": "Single PR for Ansible task/container pins",
      "matchManagers": ["ansible"],
      "groupName": "Ansible server tasks",
      "commitMessageTopic": "{{#each upgrades}}{{{depName}}}{{#unless @last}}, {{/unless}}{{/each}}"
    },
    {
      "description": "Single PR for Galaxy collections",
      "matchManagers": ["ansible-galaxy"],
      "groupName": "Ansible collections",
      "commitMessageTopic": "{{#each upgrades}}{{{depName}}}{{#unless @last}}, {{/unless}}{{/each}}"
    },
    {
      "description": "Default convenience: automerge patch, digest, minor when CI passes",
      "matchUpdateTypes": ["patch", "digest", "minor"],
      "automerge": true
    },
    {
      "description": "Never automerge major upgrades",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Terraform/Ansible: minor can change plans or runtime; CI has validate/syntax only (no cloud plan)",
      "matchManagers": ["terraform", "ansible", "ansible-galaxy"],
      "matchUpdateTypes": ["minor"],
      "automerge": false
    },
    {
      "description": "Dockerfile base images: minor needs quick glance (behaviour/ABI)",
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["minor"],
      "automerge": false
    },
    {
      "description": "Crane regex in prefect/Dockerfile.worker: minor manual (dockerfile FROM minors covered above)",
      "matchManagers": ["regex"],
      "matchPaths": ["prefect/Dockerfile.worker"],
      "matchUpdateTypes": ["minor"],
      "automerge": false
    },
    {
      "description": "devcontainer image/features: minor needs glance",
      "matchManagers": ["devcontainer"],
      "matchUpdateTypes": ["minor"],
      "automerge": false
    }
  ]
}
